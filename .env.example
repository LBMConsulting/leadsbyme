# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── Google OAuth (optional — remove if not using Google sign-in) ──────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Google Places API ─────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=""

# ── MillionVerifier email validation ─────────────────────────────────────────
MILLIONVERIFIER_API_KEY=""

# ── Pipeline tuning (optional) ────────────────────────────────────────────────
MAX_CONCURRENT_WEBSITES=3
MAX_CONCURRENT_EMAIL_VALIDATION=5
MAX_RESULTS_PER_SEARCH=20
# Set to "true" to treat catch-all domains as valid
CATCH_ALL_IS_VALID=false
# MILLIONVERIFIER_TIMEOUT=20
# LOG_LEVEL=info
